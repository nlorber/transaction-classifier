# Data source (CSV used in local dev; multi-client uses clients.yaml)
TXCLS_DATA_PATH=data/sample.csv
# TXCLS_CLIENT_REGISTRY_PATH=clients.yaml
# TXCLS_PG_ROW_LIMIT=500000

# Artifact storage
TXCLS_ARTIFACT_DIR=models

# Training
TXCLS_MIN_CLASS_SAMPLES=10
TXCLS_N_ESTIMATORS=400
TXCLS_MAX_DEPTH=7
TXCLS_LEARNING_RATE=0.03
TXCLS_PATIENCE=50

# Serving
TXCLS_API_HOST=0.0.0.0
TXCLS_API_PORT=8000
TXCLS_DEFAULT_TOP_K=3
TXCLS_RELOAD_POLL_SECS=60

# Sandbox mode (returns fixed predictions, no model needed)
# TXCLS_SANDBOX_MODE=true

# Authentication (empty = auth disabled, for local dev)
# TXCLS_API_KEYS=["key1","key2"]
# TXCLS_ADMIN_API_KEYS=["admin-key"]

# Logging
TXCLS_LOG_LEVEL=INFO
TXCLS_LOG_FORMAT=text
